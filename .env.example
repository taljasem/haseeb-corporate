# LOCAL DEV ONLY — copy to .env.local (which is gitignored)
#
# These env vars control how the Haseeb Corporate dashboard talks
# to the Corporate API. By default the dashboard runs entirely off
# the in-repo mock engine (mockEngine.js). Flip VITE_USE_MOCKS to
# "false" to route API calls to the real backend.
#
# Restart `npm run dev` after editing env vars so Vite picks them up.

# Toggle between mock engine and real API.
#   true  (default) — use mockEngine.js, no network calls
#   false           — route wired endpoints to VITE_API_BASE_URL
VITE_USE_MOCKS=true

# Base URL of the Corporate API. Only consulted when VITE_USE_MOCKS=false.
VITE_API_BASE_URL=http://localhost:3000

# Bearer token used to authenticate real API calls in LIVE mode.
# Wave 2 obsoleted the need for this in normal use — AuthContext now
# manages the token at runtime via the login flow. This env var is
# still consulted as a fallback, so existing /health smoke tests keep
# working without going through the login UI. Leave empty for Wave 2+.
# See src/scripts/generate-dev-jwt.md for how to mint one if needed.
VITE_DEV_JWT=

# Wave 2 dev convenience: pre-populate the login form with the seeded
# dev tenant credentials (dev-tenant / dev@haseeb.local / DevPassword123!).
# Set to "true" only on local dev machines. NEVER set to true in any
# deployed environment — it would leak example credentials into the
# rendered HTML.
VITE_DEV_PREFILL_CREDENTIALS=false
